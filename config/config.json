            "/mnt/c20250607/user/wanghaoran/zxy/data_and_features/zxy/sft_conversations/conversations/finetune_conversations.json"
        ],
        "stage1_whitelist_json": "/mnt/c20250607/user/wanghaoran/zxy/zxy/zxy/project/sc_showo/config/stage1_stratified_whitelist.json",
        "prefer_compact_codebook": true,
        "cluster_loader_readahead": false,
        "cluster_loader_max_readers": 2048,
        "key_cache_dir": "/mnt/c20250607/user/wanghaoran/zxy/data_and_features/per-gene-feature/per-gene-feature/per_gene_feat/key_cache",
