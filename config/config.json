    "checkpoint": {
        "save_dir": "/mnt/c20250607_hs/wanghaoran/wanghaoran/zyh/scshowo/stage1",
        "stage1_weights_path": null,
        "save_total_limit": 5,
        "resume_from": null,
        "save_optimizer_state": true,
        "save_scheduler_state": true,
        "save_random_state": true,
        "overwrite_existing": false,
        "save_format": "pytorch",
        "reset_scheduler_on_resume": false,
        "reset_epoch_on_resume": false,
        "save_trainable_only": true
